DEVELOPMENT_MODE=false
DATABASE_URL=sqlite:///data/app.db
PUBLIC_BASE_URL=https://{{ grm_fqdn }}
BACKEND_CORS_ORIGINS=https://{{ grm_fqdn }}

SESSION_SECRET_KEY=%THIS_WILL_BE_REPLACED_ON_FIRST_LAUNCH%
OIDC_ENABLED=true
# Optional override for automation writes. If empty in docker-compose,
# backend generates a shared runtime token into data/worker-api-token.
WORKER_API_TOKEN=
OIDC_CLIENT_ID={{ grm_oidc_client_id }}
OIDC_CLIENT_SECRET={{ grm_oidc_client_secret }}
OIDC_AUTHORIZE_URL=https://auth.ffh.zone/application/o/authorize/
OIDC_TOKEN_URL=https://auth.ffh.zone/application/o/token/
OIDC_USERINFO_URL=https://auth.ffh.zone/application/o/userinfo/
OIDC_LOGOUT_URL=https://auth.ffh.zone/application/o/gluon-release-manager-test/end-session/

FORGEJO_WORKFLOW_ENABLE=true
FORGEJO_URL=https://code.ffh.zone/freifunkh/firmware-forgejo
FORGEJO_WORKFLOW_FILENAME=firmware-build.yml
FORGEJO_WORKFLOW_REF=main
FORGEJO_TOKEN={{ grm_forgejo_token }}
FORGEJO_WORKFLOW_INPUTS={"gluon_commit":"%GLUON_COMMIT","site_commit":"%SITE_COMMIT","gluon_release":"%VERSION","gluon_autoupdater_branch":"%BRANCH","publish":true}

# Settings for the worker that syncs the Gluon repository and site repositories.
WORKER_GLUON_URL=https://github.com/freifunk-gluon/gluon.git
WORKER_GLUON_SYNC_ENABLED=true
WORKER_GLUON_SYNC_INTERVAL_SECONDS=3600
WORKER_GLUON_SYNC_CLEAN=false
WORKER_SITE_SYNC_ENABLED=true
WORKER_SITE_SYNC_INTERVAL_SECONDS=300
WORKER_BUILD_SYNC_ENABLED=true
WORKER_BUILD_SYNC_INTERVAL_SECONDS=5
WORKER_PUBLISH_CHECK_ENABLED=true
WORKER_PUBLISH_CHECK_INTERVAL_SECONDS=60
PUBLISH_URL=https://firmware.ffh.zone/
WORKER_RETRY_INTERVAL_SECONDS=5
WORKER_LOOP_INTERVAL_SECONDS=30
WORKER_VERBOSE=0
