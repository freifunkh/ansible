domain (ip ip6) {
  table filter {
    chain INPUT {
      proto tcp dport ({{ influx2_bind_port }}) ACCEPT {
{% for item in supernodes | dict2items %}
{% if item.value.ip4 is defined %}
        saddr {{ item.value.ip4 }};   # {{ item.key }}
{% endif %}
{% if item.value.ip6 is defined %}
        saddr {{ item.value.ip6 }};   # {{ item.key }}
{% endif %}
{% endfor %}
{% for item in exitnodes | dict2items %}
{% if item.value.ip4 is defined %}
        saddr {{ item.value.ip4 }};   # {{ item.key }}
{% endif %}
{% if item.value.ip6 is defined %}
        saddr {{ item.value.ip6 }};   # {{ item.key }}
{% endif %}
{% endfor %}
{% for item in helpernodes | dict2items %}
{% if item.value.ip4 is defined %}
        saddr {{ item.value.ip4 }};   # {{ item.key }}
{% endif %}
{% if item.value.ip6 is defined %}
        saddr {{ item.value.ip6 }};   # {{ item.key }}
{% endif %}
{% endfor %}
{% for item in proxmoxnodes | dict2items %}
{% if item.value.ip4 is defined %}
        saddr {{ item.value.ip4 }};   # {{ item.key }}
{% endif %}
{% if item.value.ip6 is defined %}
        saddr {{ item.value.ip6 }};   # {{ item.key }}
{% endif %}
{% endfor %}
{% for item in buildnodes | dict2items %}
{% if item.value.ip4 is defined and item.value.ip4 != "" %}
        saddr {{ item.value.ip4 }};   # {{ item.key }}
{% endif %}
{% if item.value.ip6 is defined and item.value.ip6 != "" %}
        saddr {{ item.value.ip6 }};   # {{ item.key }}
{% endif %}
{% endfor %}
      }
    }
  }
}
